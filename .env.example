# ============================================
# Node.js Backend
# ============================================
PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/rag-doc-qa?retryWrites=true&w=majority
JWT_SECRET=your-jwt-secret-change-this
JWT_REFRESH_SECRET=your-jwt-refresh-secret-change-this

# AWS S3 (optional — leave blank to use local uploads/ folder)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=rag-doc-qa
AWS_REGION=us-east-1

# Python AI service URL (Node.js → AI service)
AI_SERVICE_URL=http://localhost:8000

# ============================================
# Python AI Service
# ============================================
# Get free key at https://aistudio.google.com/app/apikey (no credit card needed)
GOOGLE_API_KEY=your-google-ai-api-key
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX=rag-doc-qa
PINECONE_ENVIRONMENT=us-east-1
# Node.js server URL (AI service → Node.js callback after ingestion)
SERVER_CALLBACK_URL=http://localhost:5000

# ============================================
# Frontend (Vite uses VITE_ prefix)
# ============================================
VITE_API_URL=http://localhost:5000
VITE_WS_URL=ws://localhost:5000
